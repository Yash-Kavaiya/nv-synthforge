# Local/Compose ports
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Public browser URL for the API. This is not a secret and is usually embedded
# by Next.js at build time.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Host directory persisted by Docker Compose. The container path is fixed to
# /app/artifacts in docker-compose.yml.
ARTIFACTS_PATH=./artifacts

# Optional NVIDIA NeMo Data Designer integration. Leave blank for the default
# deterministic offline path. Never expose this as NEXT_PUBLIC_NVIDIA_API_KEY.
NVIDIA_API_KEY=
